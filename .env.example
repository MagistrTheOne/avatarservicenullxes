# ==============================================================================
# avatarservicenullxes — environment variables
# ==============================================================================
# Copy this file to `.env` and fill in the values. The service loads `.env`
# automatically on startup (via pydantic-settings / os.environ).
# ==============================================================================

# ---- Runtime mode ------------------------------------------------------------
# real         — load ARACHNE-X-ULTRA-AVATAR weights, run on GPU.
# infinitetalk — run block inference via InfiniteTalk CLI (separate model stack).
# stub         — FakeArachneRuntime (reference image + waveform overlay). Dev mode.
ARACHNE_MODE=stub

# Absolute or relative path to ARACHNE-X weights (used only when ARACHNE_MODE=real).
# On RunPod this is typically `/models/ARACHNE-X-ULTRA-AVATAR`.
ARACHNE_WEIGHTS_DIR=./models/ARACHNE-X-ULTRA-AVATAR

# CUDA device ordinal. 0 == first GPU. Ignored in stub mode.
ARACHNE_CUDA_DEVICE=0

# Target inference resolution. 720 matches the ARACHNE model card; 480 can be
# useful in tests or constrained environments.
ARACHNE_FRAME_WIDTH=1280
ARACHNE_FRAME_HEIGHT=720
ARACHNE_FRAME_FPS=30

# Number of warm-up forward passes performed right after model load, so the
# first real frame does not pay the CUDA autotune / compile cost.
ARACHNE_WARMUP_FRAMES=8

# ---- InfiniteTalk runtime ----------------------------------------------------
# Used only when ARACHNE_MODE=infinitetalk.
INFINITETALK_REPO_DIR=./third_party/InfiniteTalk
INFINITETALK_PYTHON_BIN=python
INFINITETALK_CKPT_DIR=./weights/Wan2.1-I2V-14B-480P
INFINITETALK_WAV2VEC_DIR=./weights/chinese-wav2vec2-base
INFINITETALK_MODEL_DIR=./weights/InfiniteTalk/single/infinitetalk.safetensors
INFINITETALK_QUANT_DIR=
INFINITETALK_SIZE=infinitetalk-480
INFINITETALK_SAMPLE_STEPS=8
INFINITETALK_FRAME_NUM=25
INFINITETALK_MOTION_FRAME=9
INFINITETALK_TEXT_GUIDANCE_SCALE=4.0
INFINITETALK_AUDIO_GUIDANCE_SCALE=4.0
INFINITETALK_MODE=clip
INFINITETALK_TEMP_DIR=./tmp/infinitetalk

# ---- OpenAI Realtime ---------------------------------------------------------
OPENAI_API_KEY=sk-...
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_BASE_URL=https://api.openai.com/v1

# ---- Stream SFU --------------------------------------------------------------
# Coordinator credentials (server-side secret — never ship to the frontend).
STREAM_API_KEY=
STREAM_API_SECRET=

# Stream Video Coordinator REST base. Leave as default unless using a custom edge.
STREAM_BASE_URL=https://video.stream-io-api.com

# ---- Gateway callbacks -------------------------------------------------------
# The gateway (realtime-gateway on the droplet) exposes:
#   POST /avatar/events      — events from the avatar pod (avatar_ready, transcripts, ...)
# Reach it from the avatar pod over the public internet (HTTPS only in prod).
GATEWAY_BASE_URL=https://hr-gateway.example.com
GATEWAY_SHARED_TOKEN=change-me

# ---- HTTP control plane ------------------------------------------------------
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# Comma-separated list of origins the control-plane CORS layer will accept.
# Usually this is just the gateway — the candidate browser never calls us.
CORS_ALLOWED_ORIGINS=https://hr-gateway.example.com

# ---- Logging -----------------------------------------------------------------
# debug / info / warning / error
LOG_LEVEL=info

# Pretty console or structured JSON. Use json on RunPod for aggregation.
LOG_FORMAT=pretty
